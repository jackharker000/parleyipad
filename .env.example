# Parley env — server-only secrets. NEVER prefix with VITE_ — that would
# bundle them into the client. Read these in /api/* server routes only.

# LLM provider keys. Default provider is Claude; OpenAI is the switchable
# alternative — set the key for whichever provider(s) you actually want.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Model selection per tier — server picks the model from request.tier
# ("fast" for live suggestions / expand; "smart" for summaries, drafts,
# event prep, profile enrichment).
PARLEY_ANTHROPIC_FAST_MODEL=claude-haiku-4-5
PARLEY_ANTHROPIC_SMART_MODEL=claude-sonnet-4-6
PARLEY_OPENAI_FAST_MODEL=gpt-4o-mini
PARLEY_OPENAI_SMART_MODEL=gpt-4o

# STT — ElevenLabs Scribe (revisit Apple on-device after the Capacitor wrap).
ELEVENLABS_API_KEY=

# TTS — same key as STT for ElevenLabs Flash v2.5; separate key for the
# Cartesia Sonic 3 latency fallback.
CARTESIA_API_KEY=

# James's voice clone ID (ElevenLabs voice_id). Settings → People → James.
PARLEY_JAMES_VOICE_ID=

# --- Proxy hardening (both OPTIONAL; unset == prior behavior) -----------------
# The /api/* proxy holds the keys above, so on a public URL it's an open relay
# unless locked down. These two knobs raise the bar without a full auth system.

# Comma-separated allow-list of browser origins. When set, the API reflects a
# request's Origin only if it matches (otherwise echoes the first entry, so a
# mismatched browser is blocked by CORS). Unset => Access-Control-Allow-Origin
# stays "*" (fine for local dev / first deploy). Example:
#   PARLEY_ALLOWED_ORIGIN=https://parley.example.com,https://parley.vercel.app
PARLEY_ALLOWED_ORIGIN=

# Shared secret gating every /api/* route. When set, requests must send header
# `x-parley-token: <this value>` or get a 401. Unset => no gate.
# NOTE: for a public PWA the token ships in the client JS, so this only raises
# the bar; the real trust boundary is the Capacitor native wrap (token in the
# app binary, not on a public URL).
PARLEY_CLIENT_TOKEN=
