# Parley env — server-only secrets. NEVER prefix with VITE_ — that would
# bundle them into the client. Read these in /api/* server routes only.

# LLM provider keys (pick whichever providers you've selected in Settings)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Model selection per tier — server picks the model based on request.tier.
PARLEY_ANTHROPIC_FAST_MODEL=claude-haiku-4-5-20251001
PARLEY_ANTHROPIC_SMART_MODEL=claude-opus-4-7
PARLEY_OPENAI_FAST_MODEL=gpt-4o-mini
PARLEY_OPENAI_SMART_MODEL=gpt-4o

# STT (ElevenLabs Scribe)
ELEVENLABS_API_KEY=

# TTS — same key as STT for ElevenLabs; separate for Cartesia.
CARTESIA_API_KEY=

# James's voice clone ID (ElevenLabs voice_id). Settings → People → James.
PARLEY_JAMES_VOICE_ID=
